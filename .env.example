# ------------------------------------------------------------------
# Copia este archivo a .env (para desarrollo local con `vercel dev`)
# y rellena los valores. En produccion se configuran en
# Vercel -> Settings -> Environment Variables. NUNCA subas el .env real.
# ------------------------------------------------------------------

# --- Base de datos (Neon Postgres) ---
# La crea Vercel al conectar Neon desde el Marketplace y la inyecta sola.
# Para local, copia la connection string desde el dashboard de Neon.
DATABASE_URL="postgresql://usuario:password@host.neon.tech/dbname?sslmode=require"

# --- Notificaciones de leads por Telegram ---
# Crea un bot con @BotFather -> te da el token.
# Para el chat id: escribe a tu bot y consulta
# https://api.telegram.org/bot<TOKEN>/getUpdates  (campo chat.id)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- Chat / agente de IA (ya existente) ---
ANTHROPIC_API_KEY=""

# --- Panel /admin ---
ADMIN_USER="admin"
# Hash bcrypt de la contrasena. Genera uno con:  npm run hash-password -- "tuClave"
ADMIN_PASSWORD_HASH=""
# Secreto para firmar la cookie de sesion del admin (cadena larga y aleatoria).
# Genera una con:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=""

# --- Ranking del mini-juego (ya existente, opcional) ---
# Se inyectan solas al conectar un Vercel KV al proyecto.
# KV_REST_API_URL=""
# KV_REST_API_TOKEN=""
